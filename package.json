{
  "name": "@eminuckan/spine",
  "version": "0.3.5",
  "description": "Framework-agnostic SaaS primitives for auth, identity, multi-tenancy, permissions, and API access.",
  "type": "module",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "packageManager": "pnpm@9.15.9",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.mjs"
    },
    "./react-router": {
      "types": "./dist/react-router/index.d.ts",
      "import": "./dist/react-router/index.mjs"
    },
    "./react-router/server": {
      "types": "./dist/react-router/server.d.ts",
      "import": "./dist/react-router/server.mjs"
    },
    "./auth": {
      "types": "./dist/auth/index.d.ts",
      "import": "./dist/auth/index.mjs"
    },
    "./auth/server": {
      "types": "./dist/auth/server.d.ts",
      "import": "./dist/auth/server.mjs"
    },
    "./access": {
      "types": "./dist/access/index.d.ts",
      "import": "./dist/access/index.mjs"
    },
    "./permissions": {
      "types": "./dist/permissions/index.d.ts",
      "import": "./dist/permissions/index.mjs"
    },
    "./tenant": {
      "types": "./dist/tenant/index.d.ts",
      "import": "./dist/tenant/index.mjs"
    },
    "./tenant/server": {
      "types": "./dist/tenant/server.d.ts",
      "import": "./dist/tenant/server.mjs"
    },
    "./identity": {
      "types": "./dist/identity/index.d.ts",
      "import": "./dist/identity/index.mjs"
    },
    "./identity/server": {
      "types": "./dist/identity/server.d.ts",
      "import": "./dist/identity/server.mjs"
    },
    "./api-client": {
      "types": "./dist/api-client/index.d.ts",
      "import": "./dist/api-client/index.mjs"
    },
    "./api-client/server": {
      "types": "./dist/api-client/server.d.ts",
      "import": "./dist/api-client/server.mjs"
    },
    "./logging": {
      "types": "./dist/logging/index.d.ts",
      "import": "./dist/logging/index.mjs"
    },
    "./signalr": {
      "types": "./dist/signalr/index.d.ts",
      "import": "./dist/signalr/index.mjs"
    },
    "./query-client": {
      "types": "./dist/query-client/index.d.ts",
      "import": "./dist/query-client/index.mjs"
    }
  },
  "files": [
    "dist",
    "docs",
    "CHANGELOG.md",
    "CODE_OF_CONDUCT.md",
    "CONTRIBUTING.md",
    "README.md",
    "MAINTAINERS.md",
    "ROADMAP.md",
    "SECURITY.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsdown && pnpm exec tsc --emitDeclarationOnly --declaration --project tsconfig.json --outDir dist",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --max-warnings 0",
    "test": "vitest run",
    "check:public-surface": "node scripts/check-public-surface.mjs",
    "check": "pnpm run check:public-surface && pnpm run typecheck && pnpm run lint && pnpm run test && pnpm run build",
    "prepublishOnly": "pnpm run check"
  },
  "peerDependencies": {
    "@tanstack/react-query": ">=5.0.0",
    "react": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "@tanstack/react-query": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "dependencies": {
    "@microsoft/signalr": "^9.0.0",
    "ioredis": "^5.4.1",
    "jose": "^6.2.2",
    "openid-client": "^6.8.3",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "eslint": "^9.0.0",
    "globals": "^17.4.0",
    "tsdown": "^0.22.4",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.57.0",
    "vitest": "^4.1.8"
  },
  "pnpm": {
    "overrides": {
      "@microsoft/signalr>ws": "7.5.11",
      "ajv@6.12.6": "6.14.0",
      "brace-expansion@1.1.12": "1.1.13",
      "brace-expansion@5.0.4": "5.0.6",
      "flatted@3.3.3": "3.4.2",
      "js-yaml@4.1.1": "4.2.0",
      "minimatch@3.1.2": "3.1.4",
      "picomatch@4.0.3": "4.0.4"
    }
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "keywords": [
    "api-client",
    "auth",
    "framework-agnostic",
    "multi-tenant",
    "oauth",
    "oidc",
    "react-router",
    "saas",
    "signalr",
    "tanstack-query",
    "typescript",
    "zustand"
  ],
  "homepage": "https://github.com/Unitfield/spine#readme",
  "bugs": {
    "url": "https://github.com/Unitfield/spine/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Unitfield/spine.git"
  },
  "author": "Muhammet Emin Uckan <eminuckan@gmail.com>",
  "license": "MIT",
  "private": false
}
